# Usually leave this blank and sign in through the web UI. Its device-code flow
# stores a Copilot-compatible token. Set only a known-compatible token explicitly.
GITHUB_TOKEN=

# Model selection.
#   auto          -> highest Claude Haiku your account can use (fastest responses),
#                    falling back to the highest Sonnet, then gpt-4o
#   <a model id>  -> pin a specific model (e.g. gpt-4o, gpt-4.1, claude-sonnet-4.5)
# A model you pick in the web UI is remembered (.brainstem_model) and overrides this.
GITHUB_MODEL=auto

# Point to your private soul and agents (optional — defaults to ./soul.md and ./agents/)
SOUL_PATH=./soul.md
AGENTS_PATH=./agents

# Port (default: 7071)
PORT=7071

# Secure networking defaults. The server binds only to 127.0.0.1 unless LAN mode
# is explicitly enabled. Non-loopback API calls require X-Brainstem-Secret.
BRAINSTEM_LAN_MODE=false
# Private IP literals work automatically in LAN mode. Add comma-separated names
# here only when clients use a hostname such as brainstem.lan.
BRAINSTEM_ALLOWED_HOSTS=

# Password for encrypted voice.zip (Azure Speech or ElevenLabs config)
VOICE_ZIP_PASSWORD=
